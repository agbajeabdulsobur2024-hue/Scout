# 0G Compute — talks to the zg-sidecar Node service, not directly.
# Default assumes the sidecar is running locally on its default port.
# See SETUP_0G.md and zg-sidecar/.env.example for sidecar setup.
ZG_SIDECAR_URL=http://localhost:8787

# Telegram bot — create with @BotFather, paste the token here
TELEGRAM_BOT_TOKEN=
